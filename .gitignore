# upstream clones — re-fetched by scripts/setup.sh, not vendored
third_party/
benchmarks/*/upstream/

# build outputs
build/
out/
bin/
obj/
*.so
*.dll
*.dylib
*.a
*.lib
*.pdb

# python
__pycache__/
*.pyc
.venv/
.uv/
*.egg-info/
.pytest_cache/
uv.lock

# misc benchmark output (CSVs are tooling-generated; JSONs are the scoreboard and ARE committed)
benchmarks/results/*.csv

# perf / dotnet-trace captures — large binary artifacts, regeneratable
benchmarks/profiles/*.perf.data
benchmarks/profiles/*.nettrace
benchmarks/profiles/*.svg
benchmarks/profiles/*.html

# editor / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
